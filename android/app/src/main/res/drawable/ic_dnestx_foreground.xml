<?xml version="1.0" encoding="utf-8"?>
<!--
  DNestX adaptive-icon foreground — vector recreation of the D+X monogram.
  Navy fill (#14294E) with a gold outline (#E8B23A), sized to the adaptive-icon
  safe zone (centre ~72x72 of the 108x108 viewport). Background is white
  (see ic_launcher_background.xml). For a pixel-exact match to the supplied
  artwork, regenerate via Android Studio → New → Image Asset (Launcher Icons).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- "D" ring: outer silhouette with the counter punched out (evenOdd) -->
    <path
        android:fillColor="#14294E"
        android:strokeColor="#E8B23A"
        android:strokeWidth="2"
        android:fillType="evenOdd"
        android:pathData="M32,26 L58,26 C76,26 82,40 82,54 C82,68 76,82 58,82 L32,82 Z
                          M44,39 L58,39 C68,39 72,46 72,54 C72,62 68,69 58,69 L44,69 Z" />

    <!-- "X": two crossing bars sitting in the left/counter area -->
    <path
        android:fillColor="#14294E"
        android:strokeColor="#E8B23A"
        android:strokeWidth="2"
        android:pathData="M32,39 L42,39 L62,69 L52,69 Z
                          M52,39 L62,39 L42,69 L32,69 Z" />
</vector>
